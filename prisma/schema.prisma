generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE PLATFORM
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String   @default("[]") // JSON array of permission strings
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  roleId        String    @map("role_id")
  role          Role      @relation(fields: [roleId], references: [id])
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?   @map("created_by")

  @@map("users")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projects    Project[]
  employees   Employee[]
  documents   Document[]
  auditLogs   AuditLog[]
  messageLogs MessageLog[]

  @@map("companies")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  companyId  String?  @map("company_id")
  company    Company? @relation(fields: [companyId], references: [id])
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================
// PROJECTS & INVENTORY
// ============================================

model Project {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])
  type        String   @default("residential") // residential, commercial, mixed
  location    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blocks      Block[]
  files       File[]
  leads       Lead[]
  ballotEvents BallotEvent[]
  boqItems    BOQItem[]
  landRecords LandRecord[]

  @@map("projects")
}

model Block {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  createdAt DateTime @default(now())
  units     Unit[]

  @@map("blocks")
}

model Unit {
  id       String  @id @default(uuid())
  blockId  String  @map("block_id")
  block    Block   @relation(fields: [blockId], references: [id])
  plotNo   String  @map("plot_no")
  category String  @default("residential") // residential, commercial, office, apartment, villa, shop
  size     Float
  sizeUnit String  @default("sqft") @map("size_unit")
  price    Decimal @db.Decimal(15, 2)
  status   String  @default("available") // available, hold, booked, sold, possessed
  files    File[]
  billingRegistrations BmmsRegistration[]
  unitStatusHistory    UnitStatusHistory[]

  @@unique([blockId, plotNo])
  @@map("units")
}

model UnitStatusHistory {
  id         String   @id @default(uuid())
  unitId     String   @map("unit_id")
  unit       Unit     @relation(fields: [unitId], references: [id])
  oldStatus  String   @map("old_status")
  newStatus  String   @map("new_status")
  changedBy  String   @map("changed_by")
  changedAt  DateTime @default(now()) @map("changed_at")

  @@map("unit_status_history")
}

// ============================================
// CLIENTS & FILES (SAMS)
// ============================================

model Client {
  id           String   @id @default(uuid())
  regNo        String?  @unique @map("reg_no")
  name         String
  cnic         String   @unique
  phone        String
  email        String?
  address      String?
  photoUrl     String?  @map("photo_url")
  category     String?  // A, B, C for referral tracking
  source       String?  // CRM, walk-in, referral
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  files        File[]
  filePartners FilePartnership[]
  transfersFrom Transfer[] @relation("Transferor")
  transfersTo   Transfer[] @relation("Transferee")
  ballotingApplicants BallotApplicant[]
  billingRegistrations BmmsRegistration[]
  complaints   Complaint[]
  remsBuyerProfile  REMSBuyerProfile?
  remsSellerProfile REMSSellerProfile?

  @@map("clients")
}

model File {
  id           String   @id @default(uuid())
  regNo        String   @unique @map("reg_no")
  bookingNo    String?  @unique @map("booking_no")
  clientId     String   @map("client_id")
  client       Client   @relation(fields: [clientId], references: [id])
  projectId    String   @map("project_id")
  project      Project  @relation(fields: [projectId], references: [id])
  unitId       String?  @map("unit_id")
  unit         Unit?    @relation(fields: [unitId], references: [id])
  salesSource  String?  @map("sales_source")
  dealerId     String?  @map("dealer_id")
  dealer       Dealer?  @relation(fields: [dealerId], references: [id])
  status       String   @default("active") // active, cancelled, transferred, fully_paid, possessed
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  partners     FilePartnership[]
  paymentPlan  PaymentPlan?
  receipts     Receipt[]
  transfers    Transfer[]
  cancellations Cancellation[]
  refunds      Refund[]
  mergesSource  Merge[] @relation("SourceFile")
  mergesTarget  Merge[] @relation("TargetFile")
  commissions  Commission[]
  complaints   Complaint[]

  @@map("files")
}

model FilePartnership {
  id              String @id @default(uuid())
  fileId          String @map("file_id")
  file            File   @relation(fields: [fileId], references: [id])
  partnerClientId String @map("partner_client_id")
  client          Client @relation(fields: [partnerClientId], references: [id])
  sharePercentage Float  @map("share_pct")

  @@map("file_partners")
}

model Dealer {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  email         String?
  commissionSlab String? @map("commission_slab")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  files         File[]
  leads         Lead[]
  commissions   Commission[]
  calls         Call[]

  @@map("dealers")
}

// ============================================
// PAYMENTS & INSTALLMENTS
// ============================================

model PaymentPlan {
  id           String   @id @default(uuid())
  fileId       String   @unique @map("file_id")
  file         File     @relation(fields: [fileId], references: [id])
  planType     String   @map("plan_type") // standard, customized
  totalAmount  Decimal  @db.Decimal(15, 2) @map("total_amount")
  rebateAmount Decimal  @default(0) @db.Decimal(15, 2) @map("rebate_amount")
  downPayment  Decimal  @default(0) @db.Decimal(15, 2) @map("down_payment")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  installments  Installment[]

  @@map("payment_plans")
}

model Installment {
  id         String   @id @default(uuid())
  planId     String   @map("plan_id")
  plan       PaymentPlan @relation(fields: [planId], references: [id])
  instNo     Int      @map("inst_no")
  dueDate    DateTime @map("due_date")
  dueAmount  Decimal  @db.Decimal(15, 2) @map("due_amount")
  paidAmount Decimal  @default(0) @db.Decimal(15, 2) @map("paid_amount")
  status     String   @default("pending") // pending, partial, paid, overdue
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receipts   Receipt[]

  @@map("installments")
}

model Receipt {
  id           String   @id @default(uuid())
  receiptNo    String   @unique @map("receipt_no")
  fileId       String   @map("file_id")
  file         File     @relation(fields: [fileId], references: [id])
  installmentId String? @map("installment_id")
  installment  Installment? @relation(fields: [installmentId], references: [id])
  amount       Decimal  @db.Decimal(15, 2)
  mode         String   // cash, cheque, pay_order, online, bank
  instrumentNo String?  @map("instrument_no")
  chequeDate   DateTime? @map("cheque_date")
  chequeStatus String   @default("cleared") @map("cheque_status") // pending, cleared, bounced
  receivedBy   String   @map("received_by")
  receivedAt   DateTime @default(now()) @map("received_at")
  narration    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  voucherId    String?  @unique @map("voucher_id")
  voucher      Voucher? @relation(fields: [voucherId], references: [id])

  @@map("receipts")
}

// ============================================
// TRANSFERS, CANCELLATIONS, REFUNDS, MERGES
// ============================================

model Transfer {
  id            String   @id @default(uuid())
  fileId        String   @map("file_id")
  file          File     @relation(fields: [fileId], references: [id])
  fromClientId  String   @map("from_client_id")
  transferor    Client   @relation("Transferor", fields: [fromClientId], references: [id])
  toClientId    String   @map("to_client_id")
  transferee    Client   @relation("Transferee", fields: [toClientId], references: [id])
  fee           Decimal  @db.Decimal(15, 2) @default(0)
  photoUrl      String?  @map("photo_url")
  transferDate  DateTime @default(now()) @map("transfer_date")
  approvedBy    String?  @map("approved_by")
  status        String   @default("pending") // pending, approved, rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("transfers")
}

model Cancellation {
  id              String   @id @default(uuid())
  fileId          String   @map("file_id")
  file            File     @relation(fields: [fileId], references: [id])
  reason          String
  cancelledBy     String   @map("cancelled_by")
  status          String   @default("pending") // pending, approved, rejected, refunded
  paidAmount      Decimal  @default(0) @db.Decimal(15, 2) @map("paid_amount")
  deductions      Decimal  @default(0) @db.Decimal(15, 2)
  refundableAmount Decimal @default(0) @db.Decimal(15, 2) @map("refundable_amount")
  cancelDate      DateTime @default(now()) @map("cancel_date")
  reactivated     Boolean  @default(false)
  reactivatedAt   DateTime? @map("reactivated_at")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cancellations")
}

model Refund {
  id           String   @id @default(uuid())
  fileId       String   @map("file_id")
  file         File     @relation(fields: [fileId], references: [id])
  grossAmount  Decimal  @db.Decimal(15, 2) @map("gross_amount")
  deductions   Decimal  @db.Decimal(15, 2) @default(0)
  netAmount    Decimal  @db.Decimal(15, 2) @map("net_amount")
  approvedBy   String?  @map("approved_by")
  status       String   @default("pending") // pending, approved, paid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  voucherId    String?  @unique @map("voucher_id")
  voucher      Voucher? @relation(fields: [voucherId], references: [id])

  @@map("refunds")
}

model Merge {
  id            String   @id @default(uuid())
  sourceFileId  String   @map("source_file_id")
  sourceFile    File     @relation("SourceFile", fields: [sourceFileId], references: [id])
  targetFileId  String   @map("target_file_id")
  targetFile    File     @relation("TargetFile", fields: [targetFileId], references: [id])
  amount        Decimal  @db.Decimal(15, 2)
  mergedBy      String   @map("merged_by")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("merges")
}

model Commission {
  id         String   @id @default(uuid())
  fileId     String   @map("file_id")
  file       File     @relation(fields: [fileId], references: [id])
  agentId    String   @map("agent_id")
  agent      Dealer   @relation(fields: [agentId], references: [id])
  rate       Decimal  @db.Decimal(5, 2)
  amount     Decimal  @db.Decimal(15, 2)
  status     String   @default("pending") // pending, paid, reversed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("commissions")
}

// ============================================
// CRM - LEADS MANAGEMENT
// ============================================

model Lead {
  id           String   @id @default(uuid())
  name         String
  phone        String
  email        String?
  address      String?
  city         String?
  projectId    String?  @map("project_id")
  project      Project? @relation(fields: [projectId], references: [id])
  budget       Decimal? @db.Decimal(15, 2)
  leadType     String?  @map("lead_type") // buyer, seller, investor
  source       String   @default("manual") // manual, facebook, excel, whatsapp, website
  status       String   @default("new") // new, active, qualified, closed_won, closed_lost
  priority     String   @default("medium") // low, medium, high
  assignedTo   String?  @map("assigned_to")
  dealerId     String?  @map("dealer_id")
  dealer       Dealer?  @relation(fields: [dealerId], references: [id])
  notes        String?
  voiceNoteUrl String?  @map("voice_note_url")
  facebookLeadId String? @map("facebook_lead_id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  followups    Followup[]
  scores       LeadScore[]
  calls        Call[]
  closeRequests CloseLeadRequest[]
  contacts     Contact[]

  @@map("leads")
}

model Followup {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id])
  date       DateTime
  priority   String   @default("medium") // low, medium, high
   note       String?
  status     String   @default("pending") // pending, completed, cancelled
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("followups")
}

model LeadScore {
  id            String   @id @default(uuid())
  leadId        String   @map("lead_id")
  lead          Lead     @relation(fields: [leadId], references: [id])
  month         String   // YYYY-MM format
  userScore     Int      @default(0) @map("user_score")
  managerScore  Int      @default(0) @map("manager_score")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([leadId, month])
  @@map("lead_scores")
}

model CloseLeadRequest {
  id          String   @id @default(uuid())
  leadId      String   @map("lead_id")
  lead        Lead     @relation(fields: [leadId], references: [id])
  reason      String
  reasonNote  String?  @map("reason_note")
  requestedBy String   @map("requested_by")
  approvedBy  String?  @map("approved_by")
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("close_lead_requests")
}

model Contact {
  id        String   @id @default(uuid())
  leadId    String?  @map("lead_id")
  lead      Lead?    @relation(fields: [leadId], references: [id])
  name      String
  phone     String
  email     String?
  company   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

model Call {
  id           String   @id @default(uuid())
  leadId       String?  @map("lead_id")
  lead         Lead?    @relation(fields: [leadId], references: [id])
  agentId      String?  @map("agent_id")
  dealer       Dealer?  @relation(fields: [agentId], references: [id])
  phoneNumber  String   @map("phone_number")
  duration     Int      // seconds
  recordingUrl String?  @map("recording_url")
  transcript   String?
  provider     String?  // twilio, telnyx
  direction    String   @default("outbound") // inbound, outbound
  status       String   @default("completed") // completed, missed, busy
  startedAt    DateTime @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")

  @@map("calls")
}

model CalendarEvent {
  id        String   @id @default(uuid())
  title     String
  date      DateTime
  time      String?
  leadId    String?  @map("lead_id")
  userId    String   @map("user_id")
  type      String   @default("followup") // followup, meeting, reminder
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("calendar_events")
}

// ============================================
// ACCOUNTS (ACMS) - DOUBLE ENTRY
// ============================================

model ChartOfAccount {
  id       String  @id @default(uuid())
  code     String  @unique
  name     String
  type     String  // asset, liability, equity, revenue, expense
  parentId String? @map("parent_id")
  parent   ChartOfAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("AccountHierarchy")
  isActive Boolean @default(true)
  voucherEntries VoucherEntry[]

  @@map("chart_of_accounts")
}

model PostingPeriod {
  id        String   @id @default(uuid())
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now())
  vouchers  Voucher[]

  @@map("posting_periods")
}

model Voucher {
  id             String        @id @default(uuid())
  voucherNo      String        @unique @map("voucher_no")
  type           String        // payment, receipt, journal, sales, refund, adjustment, waiver, expense
  date           DateTime
  narration      String?
  createdBy      String        @map("created_by")
  postedBy       String?       @map("posted_by")
  postingPeriodId String?      @map("posting_period_id")
  postingPeriod  PostingPeriod? @relation(fields: [postingPeriodId], references: [id])
  status         String        @default("draft") // draft, pending, posted, rejected
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  entries        VoucherEntry[]
  receipt        Receipt?
  refund         Refund?

  @@map("vouchers")
}

model VoucherEntry {
  id         String   @id @default(uuid())
  voucherId  String   @map("voucher_id")
  voucher    Voucher  @relation(fields: [voucherId], references: [id])
  accountId  String   @map("account_id")
  account    ChartOfAccount @relation(fields: [accountId], references: [id])
  debit      Decimal  @default(0) @db.Decimal(15, 2)
  credit     Decimal  @default(0) @db.Decimal(15, 2)
  narration  String?
  createdAt  DateTime @default(now())

  @@map("voucher_entries")
}

// ============================================
// BILLING (BMMS) - MAINTENANCE
// ============================================

model BmmsRegistration {
  id         String   @id @default(uuid())
  regNo      String   @unique @map("reg_no")
  clientId   String?  @map("client_id")
  client     Client?  @relation(fields: [clientId], references: [id])
  unitId     String   @map("unit_id")
  unit       Unit     @relation(fields: [unitId], references: [id])
  memberName String   @map("member_name")
  nic        String?
  category   String   @default("A") // A, B, C
  referralOfficer String? @map("referral_officer")
  status     String   @default("active") // active, inactive, transferred
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  billingSchedules BillingSchedule[]
  bills      Bill[]

  @@map("bmms_registrations")
}

model BillingSchedule {
  id          String   @id @default(uuid())
  regId       String   @map("reg_id")
  registration BmmsRegistration @relation(fields: [regId], references: [id])
  chargeType  String   @map("charge_type") // rent, service, park_fee, parking, mosque_fund, cable, fine
  amount      Decimal  @db.Decimal(15, 2)
  frequency   String   // monthly, quarterly, annual, one_time
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("billing_schedules")
}

model Bill {
  id            String   @id @default(uuid())
  billNo        String   @unique @map("bill_no")
  regId         String   @map("reg_id")
  registration  BmmsRegistration @relation(fields: [regId], references: [id])
  period        String   // YYYY-MM
  totalAmount   Decimal  @db.Decimal(15, 2) @map("total_amount")
  paidAmount    Decimal  @default(0) @db.Decimal(15, 2) @map("paid_amount")
  status        String   @default("draft") // draft, finalized, partially_paid, paid, reversed
  qrCode        String?  @map("qr_code")
  dueDate       DateTime @map("due_date")
  generatedAt   DateTime @default(now()) @map("generated_at")
  finalizedAt   DateTime? @map("finalized_at")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  payments      BillPayment[]

  @@map("bills")
}

model BillPayment {
  id        String   @id @default(uuid())
  billId    String   @map("bill_id")
  bill      Bill     @relation(fields: [billId], references: [id])
  amount    Decimal  @db.Decimal(15, 2)
  mode      String   // cash, cheque, online, qr
  instrumentNo String? @map("instrument_no")
  paidAt    DateTime @default(now()) @map("paid_at")
  receivedBy String  @map("received_by")
  createdAt DateTime @default(now())

  @@map("bill_payments")
}

// ============================================
// CONSTRUCTION & STORE (C&SMS)
// ============================================

model BOQItem {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  project      Project  @relation(fields: [projectId], references: [id])
  item         String
  description  String?
  quantity     Decimal  @db.Decimal(12, 2)
  rate         Decimal  @db.Decimal(15, 2)
  budgetAmount Decimal  @db.Decimal(15, 2) @map("budget_amount")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  purchaseDemands PurchaseDemand[]
  purchaseOrders  PurchaseOrder[]

  @@map("boq_items")
}

model Vendor {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchaseOrders PurchaseOrder[]
  grnRecords     GRN[]

  @@map("vendors")
}

model PurchaseDemand {
  id           String   @id @default(uuid())
  boqId        String?  @map("boq_id")
  boq          BOQItem? @relation(fields: [boqId], references: [id])
  department   String
  item         String
  quantity     Decimal  @db.Decimal(12, 2)
  requestedBy  String   @map("requested_by")
  status       String   @default("pending") // pending, approved, rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("purchase_demands")
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  poNo         String   @unique @map("po_no")
  boqId        String?  @map("boq_id")
  boq          BOQItem? @relation(fields: [boqId], references: [id])
  vendorId     String   @map("vendor_id")
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  item         String
  quantity     Decimal  @db.Decimal(12, 2)
  rate         Decimal  @db.Decimal(15, 2)
  totalAmount  Decimal  @db.Decimal(15, 2) @map("total_amount")
  deliveryDate DateTime? @map("delivery_date")
  status       String   @default("draft") // draft, approved, delivered, cancelled
  approvedBy   String?  @map("approved_by")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  grnRecords   GRN[]

  @@map("purchase_orders")
}

model GRN {
  id          String   @id @default(uuid())
  grnNo       String   @unique @map("grn_no")
  poId        String   @map("po_id")
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  vendorId    String   @map("vendor_id")
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  item        String
  receivedQty Decimal  @db.Decimal(12, 2) @map("received_qty")
  receivedDate DateTime @default(now()) @map("received_date")
  receivedBy  String   @map("received_by")
  status      String   @default("received") // received, accepted, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("grn_records")
}

model StoreStock {
  id            String   @id @default(uuid())
  item          String
  description   String?
  qtyAvailable  Decimal  @db.Decimal(12, 2) @default(0) @map("qty_available")
  qtyReserved   Decimal  @db.Decimal(12, 2) @default(0) @map("qty_reserved")
  unit          String   @default("pcs")
  minLevel      Decimal  @db.Decimal(12, 2) @default(0) @map("min_level")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stockIssues   StockIssue[]

  @@map("store_stock")
}

model StockIssue {
  id          String   @id @default(uuid())
  stockId     String   @map("stock_id")
  stock       StoreStock @relation(fields: [stockId], references: [id])
  department  String
  quantity    Decimal  @db.Decimal(12, 2)
  issuedBy    String   @map("issued_by")
  issuedDate  DateTime @default(now()) @map("issued_date")
  returned    Boolean  @default(false)
  returnedAt  DateTime? @map("returned_at")
  createdAt   DateTime @default(now())

  @@map("stock_issues")
}

// ============================================
// COMPLAINTS (COMS)
// ============================================

model ComplaintCategory {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  defaultSupervisor String? @map("default_supervisor")
  slaHours     Int      @default(48) @map("sla_hours")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  complaints   Complaint[]

  @@map("complaint_categories")
}

model Complaint {
  id            String   @id @default(uuid())
  ticketNo      String   @unique @map("ticket_no")
  clientId      String?  @map("client_id")
  client        Client?  @relation(fields: [clientId], references: [id])
  fileId        String?  @map("file_id")
  file          File?    @relation(fields: [fileId], references: [id])
  categoryId    String   @map("category_id")
  category      ComplaintCategory @relation(fields: [categoryId], references: [id])
  memberName    String   @map("member_name")
  blockHouseNo  String   @map("block_house_no")
  details       String
  availableTime String?  @map("available_visiting_time")
  status        String   @default("new") // new, assigned, in_progress, resolved, closed
  assignedTo    String?  @map("assigned_to")
  priority      String   @default("medium") // low, medium, high, urgent
  feedback      String?
  feedbackRating Int?   @map("feedback_rating")
  loggedAt      DateTime @default(now()) @map("logged_at")
  assignedAt    DateTime? @map("assigned_at")
  resolvedAt    DateTime? @map("resolved_at")
  closedAt      DateTime? @map("closed_at")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  remarks       ComplaintRemark[]

  @@map("complaints")
}

model ComplaintRemark {
  id          String   @id @default(uuid())
  complaintId String   @map("complaint_id")
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  remark      String
  status      String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now())

  @@map("complaint_remarks")
}

// ============================================
// HRMS & PAYROLL
// ============================================

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  employees Employee[]

  @@map("departments")
}

model Designation {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  employees Employee[]

  @@map("designations")
}

model Employee {
  id           String   @id @default(uuid())
  empCode      String   @unique @map("emp_code")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  cnic         String   @unique
  phone        String
  email        String?
  address      String?
  dateOfBirth  DateTime? @map("date_of_birth")
  gender       String?
  maritalStatus String?  @map("marital_status")
  departmentId String   @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])
  designationId String  @map("designation_id")
  designation  Designation @relation(fields: [designationId], references: [id])
  joinDate     DateTime @map("join_date")
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id])
  salary       Decimal  @db.Decimal(15, 2)
  bankAccountNo String? @map("bank_account_no")
  bankName     String?  @map("bank_name")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  attendance   Attendance[]
  leaves       Leave[]
  loans        Loan[]
  payslips     Payslip[]
  dependents   EmployeeDependent[]

  @@map("employees")
}

model EmployeeDependent {
  id        String   @id @default(uuid())
  empId     String   @map("emp_id")
  employee  Employee @relation(fields: [empId], references: [id])
  name      String
  relation  String
  cnic      String?
  phone     String?
  isNominee Boolean  @default(false) @map("is_nominee")
  createdAt DateTime @default(now())

  @@map("employee_dependents")
}

model Attendance {
  id       String   @id @default(uuid())
  empId    String   @map("emp_id")
  employee Employee @relation(fields: [empId], references: [id])
  date     DateTime @db.Date
  checkIn  DateTime @map("check_in")
  checkOut DateTime? @map("check_out")
  status   String   @default("present") // present, absent, late, half_day, on_leave
  overtime Decimal? @db.Decimal(5, 2) // hours
  remarks  String?
  createdAt DateTime @default(now())

  @@unique([empId, date])
  @@map("attendance")
}

model LeaveType {
  id       String   @id @default(uuid())
  name     String   @unique // annual, casual, sick, exceptional
  daysPerYear Int  @map("days_per_year")
  isActive Boolean  @default(true)
  leaves   Leave[]

  @@map("leave_types")
}

model Leave {
  id          String    @id @default(uuid())
  empId       String    @map("emp_id")
  employee    Employee  @relation(fields: [empId], references: [id])
  typeId      String    @map("type_id")
  leaveType   LeaveType @relation(fields: [typeId], references: [id])
  fromDate    DateTime  @map("from_date")
  toDate      DateTime  @map("to_date")
  days        Int
  reason      String?
  status      String    @default("pending") // pending, approved, rejected, cancelled
  approvedBy  String?   @map("approved_by")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("leaves")
}

model LoanType {
  id       String   @id @default(uuid())
  name     String   @unique
  maxAmount Decimal? @db.Decimal(15, 2) @map("max_amount")
  maxInstallments Int? @map("max_installments")
  isActive Boolean  @default(true)
  loans    Loan[]

  @@map("loan_types")
}

model Loan {
  id           String   @id @default(uuid())
  empId        String   @map("emp_id")
  employee     Employee @relation(fields: [empId], references: [id])
  typeId       String   @map("type_id")
  loanType     LoanType @relation(fields: [typeId], references: [id])
  amount       Decimal  @db.Decimal(15, 2)
  installments Int
  monthlyDeduction Decimal @db.Decimal(15, 2) @map("monthly_deduction")
  balance      Decimal  @db.Decimal(15, 2)
  status       String   @default("active") // active, completed, written_off
  sanctionedBy String   @map("sanctioned_by")
  sanctionedAt DateTime @default(now()) @map("sanctioned_at")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("loans")
}

model PayrollRun {
  id         String   @id @default(uuid())
  month      String   // YYYY-MM
  status     String   @default("draft") // draft, processed, approved, published
  processedBy String  @map("processed_by")
  processedAt DateTime @default(now()) @map("processed_at")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  payslips   Payslip[]

  @@unique([month])
  @@map("payroll_runs")
}

model Payslip {
  id          String   @id @default(uuid())
  runId       String   @map("run_id")
  run         PayrollRun @relation(fields: [runId], references: [id])
  empId       String   @map("emp_id")
  employee    Employee @relation(fields: [empId], references: [id])
  basicSalary Decimal  @db.Decimal(15, 2) @map("basic_salary")
  allowances  Decimal  @db.Decimal(15, 2) @default(0)
  deductions  Decimal  @db.Decimal(15, 2) @default(0)
  loanDeduction Decimal @db.Decimal(15, 2) @default(0) @map("loan_deduction")
  overtime    Decimal  @db.Decimal(15, 2) @default(0)
  netSalary   Decimal  @db.Decimal(15, 2) @map("net_salary")
  status      String   @default("draft") // draft, published, paid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payslips")
}

// ============================================
// LAND MANAGEMENT (LMS)
// ============================================

model LandRecord {
  id         String   @id @default(uuid())
  projectId  String?  @map("project_id")
  project    Project? @relation(fields: [projectId], references: [id])
  moza       String
  khasraNo   String   @map("khasra_no")
  khewatNo   String   @map("khewat_no")
  khatooniNo String   @map("khatooni_no")
  ownerName  String   @map("owner_name")
  caseType   String   @map("case_type") // record, acquisition, sale, virasat
  status     String   @default("active") // active, transferred, acquired
  purchaseType String @default("full") @map("purchase_type") // partial, full
  ownershipShare Float? @map("ownership_share")
  area       Decimal? @db.Decimal(12, 2)
  areaUnit   String   @default("kanal") @map("area_unit")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("land_records")
}

// ============================================
// DIGITAL MAP (already part of Unit model)
// ============================================

// ============================================
// BALLOTING (BMS)
// ============================================

model BallotEvent {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id])
  name        String
  type        String   @default("general") // general, quota, category, phase
  runDate     DateTime @map("run_date")
  status      String   @default("draft") // draft, ready, executed, completed
  eligibilityRules String @map("eligibility_rules") // JSON
  executedBy  String?  @map("executed_by")
  executedAt  DateTime? @map("executed_at")
  seedValue   String?  @map("seed_value")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  applicants  BallotApplicant[]

  @@map("ballot_events")
}

model BallotApplicant {
  id          String     @id @default(uuid())
  ballotId    String     @map("ballot_id")
  ballot      BallotEvent @relation(fields: [ballotId], references: [id])
  clientId    String     @map("client_id")
  client      Client     @relation(fields: [clientId], references: [id])
  fileId      String?    @map("file_id")
  eligible    Boolean    @default(false)
  result      String?    // winner, loser, waitlisted
  allocatedUnitId String? @map("allocated_unit_id")
  notifiedAt  DateTime?  @map("notified_at")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("ballot_applicants")
}

// ============================================
// REMS - REAL ESTATE MANAGEMENT (BROKERAGE)
// ============================================

model REMSBuyerProfile {
  id             String   @id @default(uuid())
  clientId       String   @unique @map("client_id")
  client         Client   @relation(fields: [clientId], references: [id])
  budget         Decimal  @db.Decimal(15, 2)
  preferredArea  String?  @map("preferred_area")
  preferredType  String?  @map("preferred_type")
  preferredSize  Float?   @map("preferred_size")
  status         String   @default("active") // active, matched, closed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  requirements   REMSBuyerRequirement[]
  deals          REMSDeal[]

  @@map("rems_buyer_profiles")
}

model REMSSellerProfile {
  id            String   @id @default(uuid())
  clientId      String   @unique @map("client_id")
  client        Client   @relation(fields: [clientId], references: [id])
  propertyType  String   @map("property_type")
  propertyArea  String?  @map("property_area")
  propertySize  Float?   @map("property_size")
  askingPrice   Decimal  @db.Decimal(15, 2) @map("asking_price")
  status        String   @default("available") // available, reserved, sold
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deals         REMSDeal[]

  @@map("rems_seller_profiles")
}

model REMSBuyerRequirement {
  id              String   @id @default(uuid())
  buyerProfileId  String   @map("buyer_profile_id")
  buyerProfile    REMSBuyerProfile @relation(fields: [buyerProfileId], references: [id])
  location        String
  minSize         Float?   @map("min_size")
  maxSize         Float?   @map("max_size")
  minBudget       Decimal? @db.Decimal(15, 2) @map("min_budget")
  maxBudget       Decimal? @db.Decimal(15, 2) @map("max_budget")
  propertyType    String?  @map("property_type")
  notes           String?
  createdAt       DateTime @default(now())

  @@map("rems_buyer_requirements")
}

model REMSDeal {
  id            String   @id @default(uuid())
  buyerId       String?  @map("buyer_id")
  buyerProfile  REMSBuyerProfile? @relation(fields: [buyerId], references: [id])
  sellerId      String?  @map("seller_id")
  sellerProfile REMSSellerProfile? @relation(fields: [sellerId], references: [id])
  status        String   @default("proposed") // proposed, negotiating, agreed, closed, cancelled
  offerPrice    Decimal? @db.Decimal(15, 2) @map("offer_price")
  finalPrice    Decimal? @db.Decimal(15, 2) @map("final_price")
  commission    Decimal  @db.Decimal(15, 2) @default(0)
  commissionStatus String @default("pending") @map("commission_status") // pending, paid
  expenses      Decimal  @db.Decimal(15, 2) @default(0)
  profitLoss    Decimal? @db.Decimal(15, 2) @map("profit_loss")
  agentId       String?  @map("agent_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("rems_deals")
}

// ============================================
// DOCUMENT CONTROL (DCM)
// ============================================

model Document {
  id          String   @id @default(uuid())
  entityType  String   @map("entity_type") // employee, file, project, land_record, etc.
  entityId    String   @map("entity_id")
  companyId   String?  @map("company_id")
  company     Company? @relation(fields: [companyId], references: [id])
  name        String
  description String?
  category    String?  // contract, certificate, id_proof, legal, other
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type")
  fileSize    Int      @map("file_size")
  version     Int      @default(1)
  expiryDate  DateTime? @map("expiry_date")
  uploadedBy  String   @map("uploaded_by")
  accessLevel String   @default("private") // private, internal, public
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        DocumentTag[]
  versions    DocumentVersion[]

  @@map("documents")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id])
  version    Int
  fileUrl    String   @map("file_url")
  fileSize   Int      @map("file_size")
  uploadedBy String   @map("uploaded_by")
  changeNote String?  @map("change_note")
  createdAt  DateTime @default(now())

  @@map("document_versions")
}

model DocumentTag {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id])
  tag        String

  @@map("document_tags")
}

// ============================================
// TASK MANAGEMENT (TMS)
// ============================================

model Goal {
  id          String   @id @default(uuid())
  title       String
  description String?
  ownerId     String   @map("owner_id")
  targetDate  DateTime? @map("target_date")
  status      String   @default("active") // active, completed, archived
  completionPct Float @default(0) @map("completion_pct")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]

  @@map("goals")
}

model Task {
  id         String   @id @default(uuid())
  goalId     String?  @map("goal_id")
  goal       Goal?    @relation(fields: [goalId], references: [id])
  title      String
  description String?
  ownerId    String   @map("owner_id")
  dueDate    DateTime? @map("due_date")
  priority   String   @default("medium") // low, medium, high
  status     String   @default("pending") // pending, in_progress, completed, cancelled
  timeSpent  Int      @default(0) @map("time_spent") // minutes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  comments   TaskComment[]

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id])
  content   String
  createdBy String   @map("created_by")
  createdAt DateTime @default(now())

  @@map("task_comments")
}

// ============================================
// INTEGRATIONS - MESSAGE LOG
// ============================================

model MessageLog {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])
  channel   String   // whatsapp, sms, email
  module    String   // sams, crm, accounts, billing, hrms, complaints
  recipient String
  template  String?
  message   String?
  status    String   @default("sent") // sent, delivered, failed, pending
  externalId String? @map("external_id")
  sentAt    DateTime @default(now()) @map("sent_at")
  createdAt DateTime @default(now())

  @@map("message_logs")
}
